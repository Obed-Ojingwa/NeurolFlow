{
  "manifest_version": 3,
  "name": "NeuroFlow — Binaural Focus Engine",
  "short_name": "NeuroFlow",
  "version": "1.0.0",
  "description": "Scientifically-tuned binaural beats and ambient soundscapes for peak cognitive performance, deep focus, meditation, and restorative sleep.",
  "author": "NeuroFlow Team",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "NeuroFlow",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],

  "host_permissions": [
    "https://freesound.org/*",
    "https://api.freesound.org/*",
    "https://cdn.pixabay.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://freesound.org https://api.freesound.org https://cdn.pixabay.com"
  },

  "web_accessible_resources": [
    {
      "resources": ["offscreen.html", "audio-engine.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "neuroflow@extension",
      "strict_min_version": "109.0"
    }
  }
}